# ─── SVJ FRONTEND ENVIRONMENT VARIABLES ───
# Is file ko copy karke .env naam dedo local machine par
# cp .env.example .env

# Backend API Base URL
# Local development ke liye:
VITE_API_BASE_URL=http://localhost:5000/api/v1

# Production deployment ke liye (Render/Railway/VPS backend URL):
# VITE_API_BASE_URL=https://your-backend-url.onrender.com/api/v1
